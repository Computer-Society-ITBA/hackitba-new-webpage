# Local Development Environment Variables
# Copy this file to .env.local and fill in your values

# Firebase Client Config (Public - exposed to browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# API URL (Public) - use emulator for local dev
NEXT_PUBLIC_API_URL=http://localhost:5001/webpage-36e40/us-central1/api

# Toggle project submissions (public - exposed to browser). Set to "true" or "false".
# When set, this overrides the Firestore `settings/global.projectSubmissionsEnabled` value.
NEXT_PUBLIC_PROJECT_SUBMISSIONS_ENABLED=

# Toggle user signup (public - exposed to browser). Set to "true" or "false".
# When set, this overrides the Firestore `settings/global.signupEnabled` value.
NEXT_PUBLIC_SIGNUP_ENABLED=

# Firebase Admin SDK (Private - server-side only)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Cron Jobs Secret (Private)
CRON_SECRET=dev-secret-changeme

# Development Only
USE_FIREBASE_MOCK=false
NODE_ENV=development
