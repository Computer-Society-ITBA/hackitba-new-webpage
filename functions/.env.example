# Configuración para Scripts de Email Templates

# Project ID de Firebase (se usa por defecto: webpage-36e40)
# FIREBASE_PROJECT_ID=webpage-36e40

# Ruta a las credenciales de servicio de Firebase (opcional)
# Solo necesario si ejecutas scripts localmente sin firebase login
# GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Para usar el emulador de Firestore localmente
# FIRESTORE_EMULATOR_HOST=localhost:8080
